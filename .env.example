# ─── Fireworks AI Credits ────────────────────────────────────────────────
FIREWORKS_API_KEY=
FIREWORKS_MODEL="accounts/fireworks/models/llama-v3p1-70b-instruct"

# ─── AMD Developer Cloud (Ollama — GENUINE on-GPU compute, MI300X/ROCm) ─────
# MAIN provider. Gemma 4 26B (MoE) running locally via Ollama, hit directly
# (no Fireworks involved at all). Currently points at the AMD-provided test
# notebook; swaps to our own AMD droplet for the final build (same GPU
# specs, just a different URL). Ollama has NO built-in auth, so this must
# point at a tunnel or a firewalled address only — never expose port 11434
# to the public internet. e.g. after tunneling the notebook's port locally,
# use: http://localhost:11434/v1/chat/completions
# See HANDOFF.md for the full notebook-launch + setup steps.
AMD_OLLAMA_URL=
AMD_OLLAMA_MODEL="gemma4:26b"

# ─── Fireworks fastest serverless (pay-per-token) ─────────────────
# FALLBACK provider, used if AMD isn't reachable. GLM 5.2 - highest
# Intelligence Index of anything on Fireworks (51) and leads on coding
# benchmarks (SWE-bench Verified 77.8%), which matters since every
# specialist call here is generating executable Python. ~$1.40/M input,
# $4.40/M output tokens - a fraction of a cent per specialist call.
FIREWORKS_FAST_SERVERLESS_MODEL="accounts/fireworks/models/glm-5p2"

# ─── Backend Gateway ──────────────────────────────────────────────────────
BACKEND_BASE_URL=http://localhost:8000

# ─── General ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
