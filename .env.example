# ─── Fireworks AI Credits ────────────────────────────────────────────────
FIREWORKS_API_KEY=
FIREWORKS_MODEL="your model here"

# ─── Featherless AI (used for testing, switching to a Gemma model before submission) ──
FEATHERLESS_API_KEY="your api key here"
FEATHERLESS_MODEL="your model here"

# ─── AMD Developer Cloud (Synthesis Notebook Runner) ────────────────────
AMD_CLOUD_ENDPOINT=
AMD_CLOUD_API_KEY=
AMD_NOTEBOOK_ID=

# ─── Backend Gateway ──────────────────────────────────────────────────────
BACKEND_BASE_URL=http://localhost:8000

# ─── General ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

