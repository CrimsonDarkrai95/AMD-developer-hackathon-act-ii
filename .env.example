# ─── Ollama Specialist Endpoint () ────────────────────
OLLAMA_SPECIALIST_BASE_URL=http://localhost:11434
OLLAMA_SPECIALIST_MODEL=llama3.1

# ─── AMD Developer Cloud (Synthesis Notebook Runner) ────────────────────
AMD_CLOUD_ENDPOINT=
AMD_CLOUD_API_KEY=
AMD_NOTEBOOK_ID=

# ─── Fireworks AI Credits ────────────────────────────────────────────────
FIREWORKS_API_KEY=

# ─── Backend Gateway ──────────────────────────────────────────────────────
BACKEND_BASE_URL=http://localhost:8000

# ─── General ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
