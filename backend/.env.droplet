FIREWORKS_API_KEY=REDACTED_ROTATE_THIS_KEY_IMMEDIATELY

# MAIN provider: GENUINE on-GPU AMD compute (Gemma 4 26B via Ollama).
# This .env is for running the backend ON THE DROPLET ITSELF (Option A).
# No SSH tunnel needed here - the droplet host can reach the rocm container
# directly via its internal Docker IP. Confirm this IP is still current with:
#   docker inspect <container_id> | grep -i ipaddress
AMD_OLLAMA_URL=http://172.17.0.2:11434/v1/chat/completions
AMD_OLLAMA_MODEL=gemma4:26b

# FALLBACK provider, used if AMD isn't reachable: fastest Fireworks
# serverless, GLM 5.2 (DIRECT, pay-per-token)
FIREWORKS_FAST_SERVERLESS_MODEL=accounts/fireworks/models/glm-5p2
